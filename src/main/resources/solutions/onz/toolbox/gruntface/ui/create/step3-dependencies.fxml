<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="solutions.onz.toolbox.gruntface.ui.create.Step3Dependencies"
      spacing="8">
    <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
    <Label text="Local resources available as dependencies:"/>
    <TextField fx:id="filterField" promptText="Filter…"/>
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="rowsHost" spacing="4"/>
    </ScrollPane>
    <Label fx:id="statusLabel"/>
    <Label fx:id="errorLabel" textFill="RED" visible="false" managed="false"/>
</VBox>
